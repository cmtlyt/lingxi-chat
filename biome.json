          }
        },
        "useForOf": "off",
        "useFragmentSyntax": "off",
        "useGroupedAccessorPairs": "error",
        "useImportType": { "level": "error", "fix": "safe" },
        "useLiteralEnumMembers": "error",
        "useNamingConvention": {
          "level": "error",
          "fix": "safe",
          "options": {
            "requireAscii": true,
            "strictCase": false,
            "conventions": [
              {
                "selector": {
                  "kind": "catchParameter"
                },
                "match": "[e]|(.*)"
              },
              {
                "selector": {
                  "kind": "variable"
                },
                "match": "[ij]|(.*)"
              },
              {
                "selector": {
                  "kind": "objectLiteralMember"
                },
                "match": "[$]+|[$].*|(.*)"
              },
              {
                "selector": {
                  "kind": "typeProperty"
                },
                "match": "[$]+|[$].*|(.*)"
              },
              {
                "selector": {
                  "kind": "typeParameter"
                },
                "formats": ["PascalCase", "CONSTANT_CASE"]
              },
              {
                "match": "(.{2,})"
              },
              {
                "selector": {
                  "kind": "classProperty",
                  "modifiers": ["static", "readonly"]
                },
                "formats": ["CONSTANT_CASE"]
              },
              {
                "selector": {
                  "kind": "objectLiteralMember"
                },
                "match": "__.*|(.*)",
                "formats": ["camelCase", "CONSTANT_CASE", "PascalCase"]
              },
              {
                "selector": {
                  "kind": "typeProperty"
                },
                "match": "__.*|[$]|(.*)",
                "formats": ["camelCase", "CONSTANT_CASE", "PascalCase"]
              }
