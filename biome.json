        "useFocusableInteractive": "error",
        "useGenericFontNames": "error",
        "useHtmlLang": "error",
        "useIframeTitle": "error",
        "useSemanticElements": "error",
        "useValidAriaProps": "error",
        "useValidAriaRole": "error",
        "useValidAriaValues": "error",
        "useValidAutocomplete": "error"
