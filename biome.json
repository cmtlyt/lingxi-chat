          "level": "error",
          "options": {
            "allow": ["MIT", "Apache-2.0", "BSD-2-Clause", "BSD-3-Clause", "ISC", "0BSD", "Unlicense", "CC0-1.0"],
            "deny": [
              "GPL-1.0",
              "GPL-1.0-only",
              "GPL-1.0-or-later",
              "GPL-2.0",
